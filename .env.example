# .env.example — Copie para .env.local e preencha

# ──────────────────────────────
# Banco de dados (Vercel Postgres ou Neon)
# ──────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/mindspace?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/mindspace?sslmode=require"

# ──────────────────────────────
# NextAuth
# ──────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET="seu-secret-aqui-32-chars-minimo"
NEXTAUTH_URL="http://localhost:3000"

# ──────────────────────────────
# GitHub OAuth (opcional)
# Crie em: https://github.com/settings/apps/new
# Callback URL: http://localhost:3000/api/auth/callback/github
# ──────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ──────────────────────────────
# Google OAuth (opcional)
# Crie em: https://console.cloud.google.com
# Callback URL: http://localhost:3000/api/auth/callback/google
# ──────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
